{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Machai-Kydoimos/fpga-board-sim/boards/schema/board.schema.json",
  "title": "FPGA Board Definition",
  "description": "Board definition for the Virtual FPGA Board Simulator",
  "type": "object",
  "required": ["name", "class_name", "vendor", "device", "clocks", "default_clock_hz", "leds", "buttons", "switches"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE autocompletion"
    },
    "name": {
      "type": "string",
      "description": "Human-readable board name, e.g. 'Arty A7-35'"
    },
    "class_name": {
      "type": "string",
      "description": "Original platform class name, e.g. 'ArtyA7_35Platform'"
    },
    "vendor": {
      "type": "string",
      "description": "FPGA vendor: 'Xilinx', 'Intel', 'Lattice', 'Gowin', 'QuickLogic'"
    },
    "device": {
      "type": "string",
      "description": "FPGA device part number, e.g. 'xc7a35ti'"
    },
    "package": {
      "type": "string",
      "default": "",
      "description": "FPGA package code, e.g. 'csg324'"
    },
    "clocks": {
      "type": "array",
      "description": "Clock sources — either flat Hz values or richer objects",
      "items": {
        "oneOf": [
          { "type": "number" },
          { "$ref": "#/$defs/clock_object" }
        ]
      }
    },
    "default_clock_hz": {
      "type": "number",
      "description": "Default clock frequency in Hz used by the simulator"
    },
    "leds": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" },
      "description": "LED components on the board"
    },
    "buttons": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" },
      "description": "Button components on the board"
    },
    "switches": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" },
      "description": "Switch components on the board"
    },
    "seven_seg": {
      "oneOf": [
        { "$ref": "#/$defs/seven_seg" },
        { "type": "null" }
      ],
      "default": null,
      "description": "7-segment display definition, or null if absent"
    },
    "source": {
      "$ref": "#/$defs/source",
      "description": "Provenance tracking for this board definition"
    },
    "peripherals": {
      "type": "array",
      "items": { "$ref": "#/$defs/peripheral" },
      "default": [],
      "description": "Future: typed peripheral definitions (VGA, audio, ADC, etc.)"
    },
    "port_conventions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/port_convention" },
      "default": {},
      "description": "Future: named presets mapping generic ports to vendor-specific port names"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "clock_object": {
      "type": "object",
      "required": ["hz"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Clock resource name, e.g. 'clk50'"
        },
        "hz": {
          "type": "number",
          "description": "Frequency in Hz"
        },
        "pin": {
          "type": "string",
          "description": "FPGA pin assignment for this clock input"
        },
        "is_default": {
          "type": "boolean",
          "default": false,
          "description": "True if this is the board's default clock"
        }
      },
      "additionalProperties": false
    },
    "component": {
      "type": "object",
      "required": ["name", "number"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Resource name, e.g. 'led', 'button_up', 'rgb_led'"
        },
        "number": {
          "type": "integer",
          "description": "Resource index"
        },
        "pins": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "FPGA pin assignments"
        },
        "direction": {
          "type": "string",
          "default": "",
          "description": "Pin direction: 'i', 'o', 'io'"
        },
        "inverted": {
          "type": "boolean",
          "default": false,
          "description": "True if the component uses active-low logic"
        },
        "connector": {
          "oneOf": [
            {
              "type": "array",
              "prefixItems": [{ "type": "string" }, { "type": "integer" }],
              "items": false,
              "minItems": 2,
              "maxItems": 2
            },
            { "type": "null" }
          ],
          "default": null,
          "description": "Connector reference as [name, number], or null"
        },
        "attrs": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [{ "type": "string" }, { "type": "integer" }]
          },
          "default": {},
          "description": "IO standard and other attributes"
        },
        "color": {
          "description": "LED color when known -- a named color or a #RRGGBB hex string. Absent means unknown, and the renderer falls back to the theme default. On generated boards it flows from sync-time LED-name heuristics or the cited color registry; custom boards may set it directly (U36).",
          "oneOf": [
            { "type": "string", "enum": ["red", "green", "blue", "yellow", "orange", "amber", "white"] },
            { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          ]
        }
      },
      "additionalProperties": false
    },
    "seven_seg": {
      "type": "object",
      "required": ["num_digits", "has_dp", "is_multiplexed"],
      "properties": {
        "num_digits": { "type": "integer", "minimum": 1 },
        "has_dp": { "type": "boolean" },
        "is_multiplexed": { "type": "boolean" },
        "inverted": { "type": "boolean", "default": false },
        "select_inverted": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "description": "Where this definition came from, e.g. 'amaranth-boards' or 'custom'"
        },
        "upstream_file": {
          "type": "string",
          "description": "Original Python filename, e.g. 'arty_a7.py'"
        },
        "sync_commit": {
          "type": "string",
          "description": "Git commit SHA of the source at sync time"
        },
        "sync_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when this file was generated"
        },
        "reference_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to board documentation or vendor page"
        }
      },
      "additionalProperties": false
    },
    "convention_source": {
      "type": "object",
      "description": "Provenance for a port_convention block populated from the port-convention registry (docs/port_convention_sources/)",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Canonical constraint-file URL the convention was parsed from"
        },
        "retrieved": {
          "type": "string",
          "format": "date",
          "description": "Date the source was fetched, e.g. '2026-07-11'"
        },
        "registry_board": {
          "type": "string",
          "description": "Board identifier as listed in docs/port_convention_sources/"
        }
      },
      "additionalProperties": false
    },
    "peripheral": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Peripheral type: 'vga', 'audio', 'adc', 'uart', 'spi', 'i2c', 'sdram', 'gpio', 'ir', 'ps2'"
        },
        "name": {
          "type": "string",
          "description": "Device identifier, e.g. 'ADV7123', 'WM8731'"
        }
      },
      "additionalProperties": true
    },
    "port_convention": {
      "type": "object",
      "description": "Maps generic port names to board-specific names for a known convention",
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of this convention"
        },
        "clk": { "type": "string" },
        "leds": { "$ref": "#/$defs/port_mapping" },
        "buttons": { "$ref": "#/$defs/port_mapping" },
        "switches": { "$ref": "#/$defs/port_mapping" },
        "seven_seg": { "$ref": "#/$defs/seg_port_mapping" },
        "leds_green": {
          "$ref": "#/$defs/port_mapping",
          "description": "Secondary (e.g. green) LED bank on boards with two-color LED rows, such as Terasic DE2-115's LEDG"
        },
        "source": {
          "$ref": "#/$defs/convention_source",
          "description": "Provenance for a convention populated from the port-convention registry (absent for hand-authored blocks)"
        },
        "naming": {
          "type": "string",
          "enum": ["canonical", "project-derived", "framework-derived"],
          "description": "'canonical': port names come from the vendor/official source; 'project-derived': names were renamed by a downstream project; 'framework-derived': names come from an HDL-framework platform file (litex/amaranth) auto-derived by the sync parsers (U32). Absent means canonical (the default for existing hand-authored blocks)."
        }
      }
    },
    "port_mapping": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "width": { "type": "integer" },
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Distinct scalar port names, for boards where this resource isn't one shared vector port (e.g. Nandland Go's o_LED_1..o_LED_4, each a separate std_logic port). When present, alongside or instead of 'name'/'width' (width is redundant with len(names) but may still be set for convenience)."
        },
        "active_low": { "type": "boolean", "default": false }
      }
    },
    "seg_port_mapping": {
      "type": "object",
      "properties": {
        "style": {
          "type": "string",
          "enum": ["packed_vector", "individual", "per_segment_scalars", "scan", "serial"],
          "description": "'packed_vector': one vector spanning all digits; 'individual': one port per digit, e.g. HEX0..n; 'per_segment_scalars': one scalar port per segment per digit, e.g. o_Segment1_A; 'scan': shared segment lines multiplexed via digit_enable; 'serial': shift-register driven"
        },
        "name": { "type": "string" },
        "names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "width_per_digit": { "type": "integer" },
        "active_low": { "type": "boolean", "default": false },
        "digit_enable": {
          "$ref": "#/$defs/port_mapping",
          "description": "Digit-select/enable strobe used by the 'scan' style"
        }
      }
    }
  }
}
