# Enforce LF line endings in the repository and on checkout, on every platform.
# Matches .editorconfig (end_of_line = lf) and keeps `uv` from re-flipping
# pyproject.toml to LF on each dependency change.
* text=auto eol=lf

# Common binary types: never treat as text / never normalize (belt-and-suspenders;
# none are tracked today, but this protects them if added later).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.whl  binary

# Generated single-file embedded-core designs (regenerate; never hand-edit) — collapse in diffs
hdl/mx65_*.vhd linguist-generated=true
hdl/t80_*.vhd  linguist-generated=true
